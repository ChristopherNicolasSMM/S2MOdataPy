# Ambiente: dev (usa SQLite) | prod (usa PostgreSQL)
ENVIRONMENT=dev

# SQLite (usado em dev — caminho relativo à pasta do projeto)
SQLITE_DB=./demo.db

# PostgreSQL (necessário somente quando ENVIRONMENT=prod)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=odata_user
POSTGRES_PASSWORD=senha_aqui
POSTGRES_DB=odata_demo
